# Hosts you want to be monitored ___
# Add as many hosts as needed (HOST_1, HOST_2 ...)

TARGET_HOST_1=192.168.1.10
TARGET_USER_1=user
TARGET_PASS_1=password

TARGET_HOST_2=192.168.1.11
TARGET_USER_2=user
TARGET_PASS_2=password

# Default scanner settings ___
# Subnet prefix (e.g. 192.168.1.)
SCAN_SUBNET=192.168.1.

# IP range to scan (SCAN_SUBNET + start .. end) ___
SCAN_START=1
SCAN_END=20

# Collector settings ___
# How often to collect metrics in seconds
INTERVAL_SECONDS=30

# API settings ___
API_HOST=0.0.0.0
API_PORT=5000